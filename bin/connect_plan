#!/bin/bash
############################################################
# connect_plan — Plan differences between instance A and B, produce helper files.
############################################################
VERSION=2.0.0
SCRIPT_VERSION="$(basename $0) $VERSION"
USAGE=$(cat <<EOD
Usage: $(basename $0) [-?fev] [--only s] [--skip s] [-l a=b] [-b a=b] alias_a alias_b helper
  Plan differences between Amazon Connect instances A and B.
  --only sections  Run only these sections (comma-separated)
  --skip sections  Skip these sections (comma-separated)
  -f  Force removal of existing helper directory
  -e  Proceed even when Extended ASCII encoding may be wrong
  -l  Lambda prefix remapping (a=b)   -b  Lex bot prefix remapping (a=b)
  -v  Show version   -?  Help
  Sections: prompts,hours,queues,routing,quick_connects,modules,flows,lambdas,lex_bots,supporting,users
EOD
)
LIB_DIR="$(cd "$(dirname "$0")/lib" && pwd)"
. "$LIB_DIR/common.sh"

error() { echo -e "Error: $1" >&2; exit 1; }
add_file() { [ ! -s "$1/$2" ] && error "File missing or empty: $1/$2"; echo "$2" >> $3; }

forced=; ignore_improper_extended_ascii=
lambda_prefix_a=; lambda_prefix_b=; lex_bot_prefix_a=; lex_bot_prefix_b=
ONLY_SECTIONS=; SKIP_SECTIONS=
args=()
while [ $# -gt 0 ]; do
    case "$1" in
    --only) ONLY_SECTIONS="${2//,/ }"; shift 2;; --skip) SKIP_SECTIONS="${2//,/ }"; shift 2;;
    *) args+=("$1"); shift;; esac
done
set -- "${args[@]}"
while getopts "?fevl:b:" arg; do
    case "$arg" in
    f) forced=on;; e) ignore_improper_extended_ascii=on;; v) version;;
    l) lambda_prefix_a=${OPTARG%%=*}; lambda_prefix_b=${OPTARG#*=};;
    b) lex_bot_prefix_a=${OPTARG%%=*}; lex_bot_prefix_b=${OPTARG#*=};;
    *) usage;; esac
done
shift $((OPTIND-1))

test -z "$hex_cmd" && error "Cannot find hex conversion commands (xxd, hexdump, or od)"
check_encoding

instance_alias_dir_a=$1; instance_alias_a=$(basename "$instance_alias_dir_a")
instance_alias_dir_b=$2; instance_alias_b=$(basename "$instance_alias_dir_b")
helper=$3
lambda_prefix_a=${lambda_prefix_a:-$4}; lambda_prefix_b=${lambda_prefix_b:-$5}
[ -z "$instance_alias_a" -o -z "$instance_alias_b" -o -z "$helper" ] && usage
if [ -d $helper ]; then
    [ -n "$forced" ] && rm -fr $helper || error "Helper directory exists. Use -f to force: $helper"
fi
flow_template=$helper/flow_template.json; module_template=$helper/module_template.json

cat <<EOD
Instance Alias A: $instance_alias_a (in directory "$instance_alias_dir_a")
Instance Alias B: $instance_alias_b (in directory "$instance_alias_dir_b")
Helper: $helper
EOD
errorMsg=
[ ! -d "$instance_alias_dir_a" ] && errorMsg="$errorMsg \"$instance_alias_dir_a\""
[ ! -d "$instance_alias_dir_b" ] && errorMsg="$errorMsg \"$instance_alias_dir_b\""
[ -n "$errorMsg" ] && error "Cannot find instance directories:$errorMsg"

mkdir -p $helper
for ext in var sed new old; do eval helper_$ext=$helper/helper.$ext; > $helper/helper.$ext; done

# Instance setup (always runs — produces helper.var and base SED)
. "$LIB_DIR/plan/instance.sh"

# Plan sections
run_section "prompts"        "$LIB_DIR/plan/prompts.sh"
run_section "hours"          "$LIB_DIR/plan/hours.sh"
run_section "queues"         "$LIB_DIR/plan/queues.sh"
run_section "routing"        "$LIB_DIR/plan/routing.sh"
run_section "quick_connects" "$LIB_DIR/plan/quick_connects.sh"
run_section "modules"        "$LIB_DIR/plan/modules.sh"
run_section "flows"          "$LIB_DIR/plan/flows.sh"
run_section "lambdas"        "$LIB_DIR/plan/lambdas.sh"
run_section "lex_bots"       "$LIB_DIR/plan/lex_bots.sh"
run_section "supporting"     "$LIB_DIR/plan/supporting.sh"
run_section "users"          "$LIB_DIR/plan/users.sh"

cat <<EOD

Helper files created in: $helper/
  helper.var, helper.new, helper.old, helper.sed
All done
EOD
