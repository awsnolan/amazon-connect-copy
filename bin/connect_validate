############################################################
# 14. Contact Flow Modules
############################################################

section "Contact Flow Modules (Local)"
assert_valid_json "$instance_alias_dir/modules.json"
module_count=$(jq -s "length" "$instance_alias_dir/modules.json")
echo "  → $module_count contact flow modules in manifest"

for mfile in "$instance_alias_dir"/module_*.json; do
    [ -f "$mfile" ] || continue
    # module files contain raw flow JSON (not wrapped), validate as JSON
    assert_valid_json "$mfile" "$(basename $mfile)"
    # Must have Actions array
    action_count=$(jq ".Actions | length" "$mfile" 2>/dev/null)
    if [ -n "$action_count" ] && [ "$action_count" -gt 0 ]; then
        pass "Has Actions ($action_count): $(basename $mfile)"
    else
        fail "No Actions found: $(basename $mfile)"
    fi
    # Must have a Version field
    assert_jq_nonempty "$mfile" ".Version" "Version ($(basename $mfile))"
done

if [ -n "$do_live" ]; then
    section "Contact Flow Modules (Live)"
    jq -r ".Id + \" \" + .Name" "$instance_alias_dir/modules.json" | dos2unix |
    while read mod_id mod_name; do
        live=$(aws_connect describe-contact-flow-module \
            --instance-id "$instance_id" \
            --contact-flow-module-id "$mod_id" 2>/dev/null)
        if [ -n "$live" ]; then
            pass "Exists live: $mod_name"
            live_status=$(echo "$live" | jq -r ".ContactFlowModule.Status" | dos2unix)
            if [ "$live_status" = "published" ]; then
                pass "Published: $mod_name"
            else
                warn "Status=$live_status (not published): $mod_name"
            fi
        else
            fail "Not found live: $mod_name (id=$mod_id)"
        fi
    done
fi

############################################################
# 15. Contact Flows
############################################################

section "Contact Flows (Local)"
assert_valid_json "$instance_alias_dir/flows.json"
flow_count=$(jq -s "length" "$instance_alias_dir/flows.json")
echo "  → $flow_count contact flows in manifest"

for ffile in "$instance_alias_dir"/flow_*.json; do
    [ -f "$ffile" ] || continue
    assert_valid_json "$ffile" "$(basename $ffile)"
    # Must have Actions array
    action_count=$(jq ".Actions | length" "$ffile" 2>/dev/null)
    if [ -n "$action_count" ] && [ "$action_count" -gt 0 ]; then
        pass "Has Actions ($action_count): $(basename $ffile)"
    else
        fail "No Actions found: $(basename $ffile)"
    fi
    assert_jq_nonempty "$ffile" ".Version" "Version ($(basename $ffile))"
    assert_jq_nonempty "$ffile" ".StartAction" "StartAction ($(basename $ffile))"
    # Validate StartAction references a real action identifier
    start_id=$(jq -r ".StartAction" "$ffile" 2>/dev/null)
    id_exists=$(jq -r ".Actions[] | select(.Identifier == \"$start_id\") | .Identifier" "$ffile" 2>/dev/null)
    if [ -n "$id_exists" ]; then
        pass "StartAction resolves: $(basename $ffile)"
    else
        fail "StartAction \"$start_id\" not found in Actions: $(basename $ffile)"
    fi
done

if [ -n "$do_live" ]; then
    section "Contact Flows (Live)"
    jq -r ".Id + \" \" + .Name" "$instance_alias_dir/flows.json" | dos2unix |
    while read flow_id flow_name; do
        live=$(aws_connect describe-contact-flow \
            --instance-id "$instance_id" \
            --contact-flow-id "$flow_id" 2>/dev/null)
        if [ -n "$live" ]; then
            pass "Exists live: $flow_name"
            live_state=$(echo "$live" | jq -r ".ContactFlow.State" | dos2unix)
            if [ "$live_state" = "ACTIVE" ]; then
                pass "State=ACTIVE: $flow_name"
            else
                warn "State=$live_state (not ACTIVE): $flow_name"
            fi
        else
            fail "Not found live: $flow_name (id=$flow_id)"
        fi
    done
fi

############################################################
# 16. Cross-reference integrity checks
############################################################

section "Cross-Reference Integrity (Local)"

# Build a set of all known IDs from saved files
known_ids_file="${TEMPFILE}_ids"
> "$known_ids_file"

# Collect IDs from all manifest files
for manifest in hours queues quickconnects routings agentstatuses securityprofiles; do
    mfile="$instance_alias_dir/${manifest}.json"
    [ -f "$mfile" ] || continue
    jq -r ".Id // .HoursOfOperationId // .QuickConnectId // .RoutingProfileId // .AgentStatusId // .SecurityProfileId // empty" \
        "$mfile" 2>/dev/null >> "$known_ids_file"
done
# Also collect from detail files
for detail in "$instance_alias_dir"/hour_*.json; do
    [ -f "$detail" ] || continue
    jq -r ".HoursOfOperation.HoursOfOperationId // empty" "$detail" 2>/dev/null >> "$known_ids_file"
done
for detail in "$instance_alias_dir"/queue_*.json; do
    [ -f "$detail" ] || continue
    jq -r ".Queue.QueueId // empty" "$detail" 2>/dev/null >> "$known_ids_file"
done

known_count=$(wc -l < "$known_ids_file" | tr -d ' ')
echo "  → $known_count known IDs collected for cross-reference"

# Check flows for unresolved ARN references
unresolved=0
for ffile in "$instance_alias_dir"/flow_*.json "$instance_alias_dir"/module_*.json; do
    [ -f "$ffile" ] || continue
    # Extract all connect ARN IDs referenced in the flow
    while IFS= read -r ref_id; do
        [ -z "$ref_id" ] && continue
        if ! grep -qF "$ref_id" "$known_ids_file" 2>/dev/null; then
            warn "Unresolved reference in $(basename $ffile): $ref_id"
            unresolved=$((unresolved + 1))
        fi
    done < <(jq -r '.. | strings | select(test("arn:aws:connect:")) | split("/") | last' "$ffile" 2>/dev/null | sort -u)
done
if [ "$unresolved" -eq 0 ]; then
    pass "All flow ARN references resolve to known IDs"
fi

# Verify routing profile default outbound queues exist
for rfile in "$instance_alias_dir"/routing_*.json; do
    [ -f "$rfile" ] || continue
    [[ "$rfile" == *routingQs* ]] && continue
    rp_name=$(jq -r ".RoutingProfile.Name" "$rfile" | dos2unix)
    doq_id=$(jq -r ".RoutingProfile.DefaultOutboundQueueId" "$rfile" | dos2unix)
    if grep -qF "$doq_id" "$known_ids_file" 2>/dev/null; then
        pass "DefaultOutboundQueue resolves: $rp_name"
    else
        fail "DefaultOutboundQueue not found: $rp_name (id=$doq_id)"
    fi
done

# Verify queue HoursOfOperation references exist
for qfile in "$instance_alias_dir"/queue_*.json; do
    [ -f "$qfile" ] || continue
    q_name=$(jq -r ".Queue.Name" "$qfile" | dos2unix)
    hoo_id=$(jq -r ".Queue.HoursOfOperationId" "$qfile" | dos2unix)
    if grep -qF "$hoo_id" "$known_ids_file" 2>/dev/null; then
        pass "HoursOfOperation resolves: $q_name"
    else
        fail "HoursOfOperation not found for queue: $q_name (id=$hoo_id)"
    fi
done

rm -f "$known_ids_file"

