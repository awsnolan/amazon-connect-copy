#!/bin/bash

############################################################
#
# DR Validation Suite for Amazon Connect
# Validates a saved instance backup against a live restored instance.
# See DR_VALIDATION_SPEC.md for full test definitions.
#

VERSION=2.0.0
SCRIPT_VERSION="$(basename $0) $VERSION"

USAGE=$(cat <<EOD
Usage: $(basename $0) [-?v] [-p aws_profile] [-m mode] [-j] [-r retries] [--only layers] [--skip layers] [--target instance-id] [--target-profile profile] [--no-color] instance_alias
    Validate a saved Amazon Connect instance directory against the live instance.

    instance_alias  Alias of the Connect instance (or path to the directory saved by connect_backup)
    -p profile      AWS Profile to use (for source instance, or both if --target-profile not set)
    -m mode         Validation mode:
                      local     - Validate saved JSON files only (no AWS calls) [default]
                      live      - Compare saved files against live AWS instance
                      full      - Run both local and live validations (DR acceptance mode)
                      smoke     - Run full + functional smoke tests
                      preflight - Check target readiness only (instance reachable,
                                  credentials working, external deps available)
    -j              Output results as JSON (machine-readable)
    -r retries      Number of retries for transient AWS errors (default: 3)
    --only layers   Run only these layers (comma-separated numbers: 0-18)
    --skip layers   Skip these layers (comma-separated numbers: 0-18)
    --target id     Target instance ID to validate against (for DR: validate backup
                    against a different restored instance). If omitted, validates against
                    the source instance from the backup.
    --target-profile profile
                    AWS Profile for the target instance (if in a different account).
                    If omitted, uses -p profile for both.
    --no-color      Disable ANSI colour output (also respects NO_COLOR env var)
    -v              Show version of this script
    -?              Help
EOD
)

# Source shared library (colours, ts(), usage(), version(), dos2unix(), path_encode())
LIB_DIR="$(cd "$(dirname "$0")/lib" && pwd)"
. "$LIB_DIR/common.sh"

############################################################
# Test framework
############################################################

PASS=0
FAIL=0
WARN=0
SKIP=0
TOTAL=0
CURRENT_LAYER=""
CURRENT_LAYER_ID=""
START_TIME=$(date +%s)

# JSON accumulator arrays
JSON_LAYERS=""
JSON_FAILURES=""
JSON_CURRENT_TESTS=""
JSON_OUTPUT=
FAILED_LAYERS=""

# Layer tracking
LAYER_PASS=0
LAYER_FAIL=0
LAYER_WARN=0
LAYER_SKIP=0

layer_start() {
    # layer_start "0" "External Dependencies"
    CURRENT_LAYER_ID="$1"
    CURRENT_LAYER="$2"
    LAYER_PASS=0
    LAYER_FAIL=0
    LAYER_WARN=0
    LAYER_SKIP=0
    JSON_CURRENT_TESTS=""
    if [ -z "$JSON_OUTPUT" ]; then
        echo ""
        echo -e "${C_BOLD}━━━ Layer $1: $2 ━━━ $(ts)${C_RESET}"
    fi
}

layer_end() {
    local result="PASS"
    [ "$LAYER_FAIL" -gt 0 ] && result="FAIL"
    [ "$LAYER_FAIL" -eq 0 ] && [ "$LAYER_WARN" -gt 0 ] && result="WARN"
    if [ -n "$JSON_OUTPUT" ]; then
        local layer_json=$(cat <<EOJSON
{"id":$CURRENT_LAYER_ID,"name":"$CURRENT_LAYER","result":"$result","tests":[$JSON_CURRENT_TESTS]}
EOJSON
)
        [ -n "$JSON_LAYERS" ] && JSON_LAYERS="$JSON_LAYERS,"
        JSON_LAYERS="$JSON_LAYERS$layer_json"
    fi
}

_record_test() {
    # _record_test "1.1" "PASS" "Instance reachable" "detail text"
    local id="$1" result="$2" label="$3" detail="${4:-}"
    TOTAL=$((TOTAL + 1))
    local json_entry="{\"id\":\"$id\",\"result\":\"$result\",\"label\":\"$label\""
    if [ -n "$detail" ]; then
        # Escape quotes in detail for JSON safety
        detail="${detail//\"/\\\"}"
        json_entry="$json_entry,\"detail\":\"$detail\""
    fi
    json_entry="$json_entry}"
    [ -n "$JSON_CURRENT_TESTS" ] && JSON_CURRENT_TESTS="$JSON_CURRENT_TESTS,"
    JSON_CURRENT_TESTS="$JSON_CURRENT_TESTS$json_entry"
}

pass() {
    local id="$1" label="$2"
    PASS=$((PASS + 1))
    LAYER_PASS=$((LAYER_PASS + 1))
    _record_test "$id" "PASS" "$label"
    [ -z "$JSON_OUTPUT" ] && echo -e "  ${C_PASS}[$id] ✓ $label${C_RESET}"
}

fail() {
    local id="$1" label="$2" detail="${3:-}"
    FAIL=$((FAIL + 1))
    LAYER_FAIL=$((LAYER_FAIL + 1))
    _record_test "$id" "FAIL" "$label" "$detail"
    if [ -z "$JSON_OUTPUT" ]; then
        echo -e "  ${C_FAIL}[$id] ✗ $label${C_RESET}" >&2
        [ -n "$detail" ] && echo -e "  ${C_FAIL}       → $detail${C_RESET}" >&2
    fi
    # Track which layer prefixes have failures (for remediation)
    local layer_prefix="${id%%.*}"
    case " $FAILED_LAYERS " in
        *" $layer_prefix "*) ;;  # already recorded
        *) FAILED_LAYERS="$FAILED_LAYERS $layer_prefix";;
    esac
    # Accumulate failures for JSON summary
    local fail_json="{\"id\":\"$id\",\"layer\":\"$CURRENT_LAYER\",\"label\":\"$label\""
    [ -n "$detail" ] && fail_json="$fail_json,\"detail\":\"${detail//\"/\\\"}\""
    fail_json="$fail_json}"
    [ -n "$JSON_FAILURES" ] && JSON_FAILURES="$JSON_FAILURES,"
    JSON_FAILURES="$JSON_FAILURES$fail_json"
}

warn() {
    local id="$1" label="$2" detail="${3:-}"
    WARN=$((WARN + 1))
    LAYER_WARN=$((LAYER_WARN + 1))
    _record_test "$id" "WARN" "$label" "$detail"
    if [ -z "$JSON_OUTPUT" ]; then
        echo -e "  ${C_WARN}[$id] ⚠ $label${C_RESET}"
        [ -n "$detail" ] && echo -e "  ${C_WARN}       → $detail${C_RESET}"
    fi
}

skip() {
    local id="$1" label="$2" detail="${3:-}"
    SKIP=$((SKIP + 1))
    LAYER_SKIP=$((LAYER_SKIP + 1))
    _record_test "$id" "SKIP" "$label" "$detail"
    [ -z "$JSON_OUTPUT" ] && echo -e "  ${C_SKIP}[$id] - $label${detail:+ ($detail)}${C_RESET}"
}

############################################################
# AWS CLI wrapper with retry
############################################################

export AWS_DEFAULT_OUTPUT=json
MAX_RETRIES=3
RETRY_DELAY=2

aws_retry() {
    # Retry wrapper for AWS CLI calls. Retries on throttle/transient errors.
    local attempt=0
    local result
    while [ $attempt -lt $MAX_RETRIES ]; do
        result=$(eval "$@" 2>"$TEMPERR")
        local rc=$?
        if [ $rc -eq 0 ]; then
            echo "$result"
            return 0
        fi
        # Check if retryable
        if grep -qi "Throttling\|RequestLimitExceeded\|ServiceUnavailable\|InternalError" "$TEMPERR" 2>/dev/null; then
            attempt=$((attempt + 1))
            [ $attempt -lt $MAX_RETRIES ] && sleep $((RETRY_DELAY * attempt))
        else
            # Non-retryable error
            cat "$TEMPERR" >&2
            return $rc
        fi
    done
    cat "$TEMPERR" >&2
    return 1
}

aws_connect() {
    local cmd="aws connect --output json$profile_flag"
    local ii
    for ii; do
        [[ "$ii" == *" "* || "$ii" == *"("* || "$ii" == *")"* ]] && cmd="$cmd \"$ii\"" || cmd="$cmd $ii"
    done
    aws_retry "$cmd"
}

aws_lambda() {
    local cmd="aws lambda --output json$profile_flag"
    local ii
    for ii; do
        [[ "$ii" == *" "* || "$ii" == *"("* || "$ii" == *")"* ]] && cmd="$cmd \"$ii\"" || cmd="$cmd $ii"
    done
    aws_retry "$cmd"
}

aws_lex_v2() {
    local cmd="aws lexv2-models --output json$profile_flag"
    local ii
    for ii; do
        [[ "$ii" == *" "* || "$ii" == *"("* || "$ii" == *")"* ]] && cmd="$cmd \"$ii\"" || cmd="$cmd $ii"
    done
    aws_retry "$cmd"
}

aws_lex_classic() {
    local cmd="aws lex-models --output json$profile_flag"
    local ii
    for ii; do
        [[ "$ii" == *" "* || "$ii" == *"("* || "$ii" == *")"* ]] && cmd="$cmd \"$ii\"" || cmd="$cmd $ii"
    done
    aws_retry "$cmd"
}

aws_cases() {
    local cmd="aws connectcases --output json$profile_flag"
    local ii
    for ii; do
        [[ "$ii" == *" "* || "$ii" == *"("* || "$ii" == *")"* ]] && cmd="$cmd \"$ii\"" || cmd="$cmd $ii"
    done
    aws_retry "$cmd"
}

aws_campaigns() {
    local cmd="aws connect-campaigns-v2 --output json$profile_flag"
    local ii
    for ii; do
        [[ "$ii" == *" "* || "$ii" == *"("* || "$ii" == *")"* ]] && cmd="$cmd \"$ii\"" || cmd="$cmd $ii"
    done
    aws_retry "$cmd"
}

############################################################
# Comparison helpers
############################################################

# Compare two values, treating null/empty/missing as equivalent
nullable_eq() {
    local a="${1:-}" b="${2:-}"
    # Normalize: null, empty string, "null" all treated as empty
    [ "$a" = "null" ] && a=""
    [ "$b" = "null" ] && b=""
    # Trim whitespace
    a=$(echo "$a" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    b=$(echo "$b" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ "$a" = "$b" ]
}

# Compare two JSON arrays (order-independent) — returns 0 if same set
json_arrays_equal() {
    local file_a="$1" file_b="$2"
    local sorted_a sorted_b
    sorted_a=$(jq -S 'sort' "$file_a" 2>/dev/null)
    sorted_b=$(jq -S 'sort' "$file_b" 2>/dev/null)
    [ "$sorted_a" = "$sorted_b" ]
}

# Compare two sorted string lists (one per line)
lists_equal() {
    local list_a="$1" list_b="$2"
    local sorted_a sorted_b
    sorted_a=$(echo "$list_a" | sort)
    sorted_b=$(echo "$list_b" | sort)
    [ "$sorted_a" = "$sorted_b" ]
}

# Resolve a resource ID to a name using saved manifests
# resolve_name_by_id "queues.json" ".Id" ".Name" "queue-id-123"
resolve_name_by_id() {
    local manifest="$1" id_field="$2" name_field="$3" target_id="$4"
    jq -r "select($id_field == \"$target_id\") | $name_field" \
        "$instance_alias_dir/$manifest" 2>/dev/null | dos2unix | head -1
}

# Compare tags between saved and live resource.
# Args: saved_tags_json live_tags_json
# Returns: 0 if equal, 1 if different
# Sets TAGS_DIFF_DETAIL with human-readable difference (for fail messages)
TAGS_DIFF_DETAIL=""
compare_tags() {
    local saved_json="$1" live_json="$2"
    TAGS_DIFF_DETAIL=""
    # Normalize: null/{}/empty → empty object
    local saved live
    saved=$(echo "${saved_json:-{}}" | jq -S 'if . == null then {} else . end' 2>/dev/null || echo "{}")
    live=$(echo "${live_json:-{}}" | jq -S 'if . == null then {} else . end' 2>/dev/null || echo "{}")
    if [ "$saved" = "$live" ]; then
        return 0
    fi
    # Build diff detail
    local added removed changed
    added=$(jq -n --argjson s "$saved" --argjson l "$live" '$l | to_entries | map(select(.key as $k | $s | has($k) | not)) | map(.key) | join(", ")' 2>/dev/null)
    removed=$(jq -n --argjson s "$saved" --argjson l "$live" '$s | to_entries | map(select(.key as $k | $l | has($k) | not)) | map(.key) | join(", ")' 2>/dev/null)
    changed=$(jq -n --argjson s "$saved" --argjson l "$live" '[$s | to_entries[] | select($l[.key] != null and $l[.key] != .value) | .key] | join(", ")' 2>/dev/null)
    local details=""
    [ -n "$added" ] && [ "$added" != '""' ] && [ "$added" != "" ] && details="added: $added"
    [ -n "$removed" ] && [ "$removed" != '""' ] && [ "$removed" != "" ] && details="${details:+$details; }removed: $removed"
    [ -n "$changed" ] && [ "$changed" != '""' ] && [ "$changed" != "" ] && details="${details:+$details; }changed: $changed"
    TAGS_DIFF_DETAIL="${details:-tags differ}"
    return 1
}

# Compare description fields between saved and live resource.
# Treats null, empty string, "null", and missing as equivalent.
# Args: saved_description live_description
# Returns: 0 if equal, 1 if different
compare_description() {
    local saved="${1:-}" live="${2:-}"
    # Normalize null variants to empty
    [ "$saved" = "null" ] && saved=""
    [ "$live" = "null" ] && live=""
    # Trim whitespace and collapse internal whitespace
    saved=$(echo "$saved" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr -s '[:space:]' ' ')
    live=$(echo "$live" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr -s '[:space:]' ' ')
    [ "$saved" = "$live" ]
}

############################################################
# Flow/Module content normalization
#
# Replaces instance-specific IDs and ARNs with canonical names so that
# content from two different instances (source backup vs live target) can
# be compared without false positives from ID differences.
#
# Normalization rules:
#   - Queue IDs → queue:<Name>
#   - Flow IDs → flow:<Name>
#   - Module IDs → module:<Name>
#   - Prompt IDs → prompt:<Name>
#   - Lambda ARNs → lambda:<FunctionName>
#   - Lex V2 bot ARNs → lex:<BotName>
#   - Instance ID in ARNs → instance:NORMALIZED
#   - Account IDs in ARNs → account:NORMALIZED
#   - UUIDs not in any manifest are left unchanged (dead refs / opaque)
############################################################

# Build sed script for normalizing source content
# Writes to the file path given as $1
_build_normalize_sed() {
    local output_file="$1"
    local manifest_dir="$2"
    > "$output_file"

    # Instance ID → canonical
    local inst_id
    inst_id=$(jq -r '.Id // empty' "$manifest_dir/instance.json" 2>/dev/null | dos2unix)
    [ -n "$inst_id" ] && echo "s%$inst_id%instance:NORMALIZED%g" >> "$output_file"

    # Account ID in ARNs → canonical
    local inst_arn
    inst_arn=$(jq -r '.Arn // empty' "$manifest_dir/instance.json" 2>/dev/null | dos2unix)
    if [ -n "$inst_arn" ]; then
        local acct_id region
        acct_id=$(echo "$inst_arn" | cut -d: -f5)
        region=$(echo "$inst_arn" | cut -d: -f4)
        [ -n "$acct_id" ] && echo "s%:$acct_id:%:account:NORMALIZED:%g" >> "$output_file"
        [ -n "$region" ] && echo "s%:$region:%:region:NORMALIZED:%g" >> "$output_file"
    fi

    # Queues: ID → queue:<Name>
    if [ -f "$manifest_dir/queues.json" ]; then
        jq -r '.Id + "\t" + .Name' "$manifest_dir/queues.json" 2>/dev/null | tr -d '\r' |
        while IFS=$'\t' read -r qid qname; do
            [ -z "$qid" ] && continue
            echo "s%$qid%queue:${qname//\%/%%}%g" >> "$output_file"
        done
    fi

    # Flows: ID → flow:<Name>
    if [ -f "$manifest_dir/flows.json" ]; then
        jq -r '.Id + "\t" + .Name' "$manifest_dir/flows.json" 2>/dev/null | tr -d '\r' |
        while IFS=$'\t' read -r fid fname; do
            [ -z "$fid" ] && continue
            echo "s%$fid%flow:${fname//\%/%%}%g" >> "$output_file"
        done
    fi

    # Modules: ID → module:<Name>
    if [ -f "$manifest_dir/modules.json" ]; then
        jq -r '.Id + "\t" + .Name' "$manifest_dir/modules.json" 2>/dev/null | tr -d '\r' |
        while IFS=$'\t' read -r mid mname; do
            [ -z "$mid" ] && continue
            echo "s%$mid%module:${mname//\%/%%}%g" >> "$output_file"
        done
    fi

    # Prompts: ID → prompt:<Name>
    if [ -f "$manifest_dir/prompts.json" ]; then
        jq -r '.Id + "\t" + .Name' "$manifest_dir/prompts.json" 2>/dev/null | tr -d '\r' |
        while IFS=$'\t' read -r pid pname; do
            [ -z "$pid" ] && continue
            echo "s%$pid%prompt:${pname//\%/%%}%g" >> "$output_file"
        done
    fi

    # Lambda ARNs → lambda:<FunctionName>
    # Match pattern: arn:aws:lambda:<region>:<account>:function:<name>
    # Replace the entire ARN with lambda:<name>
    echo 's%arn:aws:lambda:[^:]*:[^:]*:function:\([^:"]*\)%lambda:\1%g' >> "$output_file"

    # Lex V2 ARNs → lex:bot/<botId>/<aliasId> (IDs stay since we can't resolve name from ARN alone)
    # Actually, normalize account+region prefix only — bot-specific IDs handled by instance/account rules above
    echo 's%arn:aws:lex:[^:]*:[^:]*:%lex:NORMALIZED:%g' >> "$output_file"
}

# Normalize flow/module JSON content using a pre-built sed script
# Usage: normalize_flow_content <sed_script_file> <content_json_string>
# Outputs normalized JSON to stdout
normalize_flow_content() {
    local sed_file="$1"
    # Read from stdin, apply sed normalization, then sort JSON keys
    sed -f "$sed_file" | jq -S '.' 2>/dev/null
}

############################################################
# Argument parsing
############################################################

profile=
mode=local
json_output=
max_retries=3
VALIDATE_ONLY=
VALIDATE_SKIP=
TARGET_INSTANCE_ID=
TARGET_PROFILE=

# Handle long options before getopts
args=()
while [ $# -gt 0 ]; do
    case "$1" in
    --only)           VALIDATE_ONLY="${2//,/ }"; shift 2;;
    --skip)           VALIDATE_SKIP="${2//,/ }"; shift 2;;
    --target)         TARGET_INSTANCE_ID="$2"; shift 2;;
    --target-profile) TARGET_PROFILE="$2"; shift 2;;
    --no-color)       USE_COLOR=off; C_PASS=''; C_FAIL=''; C_WARN=''; C_SKIP=''; C_BOLD=''; C_RESET=''; shift;;
    *)                args+=("$1"); shift;;
    esac
done
set -- "${args[@]}"

while getopts "?vjp:m:r:" arg; do
    case "$arg" in
    v)  version;;
    j)  json_output=on; JSON_OUTPUT=on;;
    p)  profile=$OPTARG;;
    m)  mode=$OPTARG;;
    r)  max_retries=$OPTARG; MAX_RETRIES=$OPTARG;;
    *)  usage;;
    esac
done
shift $((OPTIND-1))

instance_alias_dir=$1
instance_alias=$(basename "$instance_alias_dir")
profile_flag=${profile:+ --profile $profile}

if [ -z "$instance_alias_dir" ]; then
    usage
fi

# If --target-profile is set, use it for all live API calls; otherwise use -p
if [ -n "$TARGET_PROFILE" ]; then
    profile_flag=" --profile $TARGET_PROFILE"
fi

case "$mode" in
local|live|full|smoke|preflight) ;;
*) echo "Invalid mode: $mode. Use local, live, full, smoke, or preflight." >&2; exit 2;;
esac

do_local=
do_live=
do_smoke=
do_preflight=
case "$mode" in
local)     do_local=on;;
live)      do_live=on;;
full)      do_local=on; do_live=on;;
smoke)     do_local=on; do_live=on; do_smoke=on;;
preflight) do_live=on; do_preflight=on;;
esac

# Temp files
TEMPFILE=$(mktemp)
TEMPFILE2=${TEMPFILE}_2
TEMPERR=${TEMPFILE}_err
TEMPJSON=${TEMPFILE}_json
trap 'rm -f $TEMPFILE $TEMPFILE2 $TEMPERR $TEMPJSON' EXIT
touch $TEMPFILE $TEMPFILE2 $TEMPERR $TEMPJSON

maxitems=999

############################################################
# Header
############################################################

if [ ! -d "$instance_alias_dir" ]; then
    echo "Error: Instance directory does not exist: $instance_alias_dir" >&2
    echo "Run connect_save first to populate the directory." >&2
    exit 2
fi

# Load instance metadata
# source_instance_id: the ID from the backup (used for reference)
# instance_id: the ID to validate against (target if specified, otherwise source)
source_instance_id=""
if [ -f "$instance_alias_dir/instance.json" ]; then
    source_instance_id=$(jq -r ".Id // empty" "$instance_alias_dir/instance.json" 2>/dev/null | dos2unix)
fi

if [ -n "$TARGET_INSTANCE_ID" ]; then
    instance_id="$TARGET_INSTANCE_ID"
else
    instance_id="$source_instance_id"
fi

target_label=""
if [ -n "$TARGET_INSTANCE_ID" ]; then
    target_label="$TARGET_INSTANCE_ID"
else
    target_label="(same as source)"
fi

if [ -z "$JSON_OUTPUT" ]; then
    echo -e "${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
    echo -e "${C_BOLD}  connect_validate $VERSION${C_RESET}"
    echo "  Source   : $instance_alias"
    echo "  Directory: $instance_alias_dir"
    echo "  Target   : $target_label"
    echo "  Mode     : $mode"
    echo "  Profile  : ${TARGET_PROFILE:-${profile:-${AWS_PROFILE:-(default)}}}"
    echo -e "${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
fi

############################################################
# Pre-flight: verify instance reachable if live mode
############################################################

if [ -n "$do_live" ] && [ -z "$instance_id" ]; then
    echo "Error: Cannot run live validation — no instance ID available." >&2
    echo "Either the backup directory must contain instance.json with an Id," >&2
    echo "or use --target <instance-id> to specify the target instance." >&2
    exit 2
fi

# Layer filter: should this layer run?
should_run_layer() {
    local layer_num="$1"
    if [ -n "$VALIDATE_ONLY" ]; then
        echo "$VALIDATE_ONLY" | grep -qw "$layer_num" && return 0 || return 1
    fi
    if [ -n "$VALIDATE_SKIP" ]; then
        echo "$VALIDATE_SKIP" | grep -qw "$layer_num" && return 1 || return 0
    fi
    return 0
}

############################################################
# Cross-account target mapping
#
# When --target is set (different instance), resources have different IDs.
# Build name→ID maps by listing resources on the target once upfront.
############################################################

CROSS_ACCOUNT=
[ -n "$TARGET_INSTANCE_ID" ] && [ "$TARGET_INSTANCE_ID" != "$source_instance_id" ] && CROSS_ACCOUNT=on

# Map files
MAP_HOURS="${TEMPFILE}_map_hours"
MAP_QUEUES="${TEMPFILE}_map_queues"
MAP_ROUTINGS="${TEMPFILE}_map_routings"
MAP_SECURITY="${TEMPFILE}_map_security"
MAP_USERS="${TEMPFILE}_map_users"
MAP_QC="${TEMPFILE}_map_qc"
MAP_FLOWS="${TEMPFILE}_map_flows"
MAP_MODULES="${TEMPFILE}_map_modules"
MAP_STATUSES="${TEMPFILE}_map_statuses"
MAP_VIEWS="${TEMPFILE}_map_views"
touch "$MAP_HOURS" "$MAP_QUEUES" "$MAP_ROUTINGS" "$MAP_SECURITY" "$MAP_USERS" \
      "$MAP_QC" "$MAP_FLOWS" "$MAP_MODULES" "$MAP_STATUSES" "$MAP_VIEWS"

build_target_maps() {
    # Build name→ID JSON maps from target instance list APIs
    [ -z "$CROSS_ACCOUNT" ] && return 0
    [ -z "$JSON_OUTPUT" ] && echo "  Building cross-account resource maps..."

    # Hours of operations
    aws_connect list-hours-of-operations --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.HoursOfOperationSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_HOURS"

    # Queues
    aws_connect list-queues --instance-id "$instance_id" --max-items $maxitems --queue-types STANDARD 2>/dev/null | \
        jq -r '.QueueSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_QUEUES"

    # Routing profiles
    aws_connect list-routing-profiles --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.RoutingProfileSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_ROUTINGS"

    # Security profiles
    aws_connect list-security-profiles --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.SecurityProfileSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_SECURITY"

    # Users
    aws_connect list-users --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.UserSummaryList // [] | map({(.Username): .Id}) | add // {}' > "$MAP_USERS"

    # Quick connects
    aws_connect list-quick-connects --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.QuickConnectSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_QC"

    # Contact flows
    aws_connect list-contact-flows --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.ContactFlowSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_FLOWS"

    # Contact flow modules
    aws_connect list-contact-flow-modules --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.ContactFlowModulesSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_MODULES"

    # Agent statuses
    aws_connect list-agent-statuses --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.AgentStatusSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_STATUSES"

    # Views
    aws_connect list-views --instance-id "$instance_id" --max-items $maxitems 2>/dev/null | \
        jq -r '.ViewsSummaryList // [] | map({(.Name): .Id}) | add // {}' > "$MAP_VIEWS"

    [ -z "$JSON_OUTPUT" ] && echo "  Maps built."
}

# Resolve a resource name to target ID using the maps
# Usage: resolve_target_id MAP_FILE "resource name"
# Returns: target ID or empty
resolve_target_id() {
    local map_file="$1"
    local name="$2"
    jq -r ".[\"$name\"] // empty" "$map_file" 2>/dev/null
}

# Get the effective ID for a resource — uses source ID if same instance, resolves by name if cross-account
# Usage: effective_id MAP_FILE source_id source_name
# Returns: the ID to use for describe calls
effective_id() {
    local map_file="$1"
    local src_id="$2"
    local src_name="$3"
    if [ -z "$CROSS_ACCOUNT" ]; then
        echo "$src_id"
    else
        resolve_target_id "$map_file" "$src_name"
    fi
}

############################################################
# Preflight mode: target readiness check
############################################################


############################################################
# Load layer validation functions
############################################################

VALIDATE_LIB="$LIB_DIR/validate"

. "$VALIDATE_LIB/preflight.sh"
. "$VALIDATE_LIB/layer_0_deps.sh"
. "$VALIDATE_LIB/layer_1_instance.sh"
. "$VALIDATE_LIB/layer_2_hours.sh"
. "$VALIDATE_LIB/layer_3_queues.sh"
. "$VALIDATE_LIB/layer_4_routing.sh"
. "$VALIDATE_LIB/layer_5_security.sh"
. "$VALIDATE_LIB/layer_6_hierarchy.sh"
. "$VALIDATE_LIB/layer_7_users.sh"
. "$VALIDATE_LIB/layer_8_quick_connects.sh"
. "$VALIDATE_LIB/layer_9_10_flows.sh"
. "$VALIDATE_LIB/layer_11_phone.sh"
. "$VALIDATE_LIB/layer_12_integrations.sh"
. "$VALIDATE_LIB/layer_13_email.sh"
. "$VALIDATE_LIB/layer_14_supporting.sh"
. "$VALIDATE_LIB/layer_15_cases.sh"
. "$VALIDATE_LIB/layer_16_campaigns.sh"
. "$VALIDATE_LIB/layer_17_integrity.sh"
. "$VALIDATE_LIB/layer_18_smoke.sh"

# Main execution
############################################################

# Preflight mode: only run the readiness check
if [ -n "$do_preflight" ]; then
    validate_preflight
else
    # Build cross-account name→ID maps if targeting a different instance
    if [ -n "$do_live" ] && [ -n "$CROSS_ACCOUNT" ]; then
        build_target_maps
    fi

    # Run layers in dependency order
    if [ -n "$do_live" ]; then
        should_run_layer 0 && validate_layer_0
    fi
    should_run_layer 1 && validate_layer_1
    should_run_layer 2 && validate_layer_2
    should_run_layer 3 && validate_layer_3
    should_run_layer 4 && validate_layer_4
    should_run_layer 5 && validate_layer_5
    should_run_layer 6 && validate_layer_6
    should_run_layer 7 && validate_layer_7
    should_run_layer 8 && validate_layer_8
    # Layers 9+10 are combined (modules + flows)
    if should_run_layer 9 || should_run_layer 10; then
        validate_layer_9_10
    fi
    should_run_layer 11 && validate_layer_11
    should_run_layer 12 && validate_layer_12
    should_run_layer 13 && validate_layer_13
    should_run_layer 14 && validate_layer_14
    should_run_layer 15 && validate_layer_15
    should_run_layer 16 && validate_layer_16
    should_run_layer 17 && validate_layer_17
    if [ -n "$do_smoke" ]; then
        should_run_layer 18 && validate_layer_18
    fi
fi

############################################################
# Output results
############################################################

############################################################
# Remediation Guide — printed after FAIL result
############################################################

. "$VALIDATE_LIB/remediation.sh"

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

if [ -n "$JSON_OUTPUT" ]; then
    # JSON output mode
    result="PASS"
    [ "$FAIL" -gt 0 ] && result="FAIL"
    cat <<EOJSON
{
  "version": "$VERSION",
  "mode": "$mode",
  "instance": "$instance_alias",
  "source_instance_id": "$source_instance_id",
  "target_instance_id": "$instance_id",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "duration_seconds": $DURATION,
  "summary": {
    "total": $TOTAL,
    "pass": $PASS,
    "fail": $FAIL,
    "warn": $WARN,
    "skip": $SKIP
  },
  "result": "$result",
  "layers": [$JSON_LAYERS],
  "failures": [$JSON_FAILURES]
}
EOJSON
else
    # Human-readable summary
    echo ""
    echo -e "${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
    echo -e "${C_BOLD}  Results${C_RESET}"
    echo -e "${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
    echo -e "  ${C_PASS}✓ Passed  : $PASS${C_RESET}"
    echo -e "  ${C_FAIL}✗ Failed  : $FAIL${C_RESET}"
    echo -e "  ${C_WARN}⚠ Warnings: $WARN${C_RESET}"
    echo -e "  ${C_SKIP}- Skipped : $SKIP${C_RESET}"
    echo "  Duration  : ${DURATION}s"
    echo -e "${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"

    if [ "$FAIL" -gt 0 ]; then
        echo ""
        echo -e "  ${C_FAIL}${C_BOLD}RESULT: FAIL ($FAIL test(s) failed)${C_RESET}"
        echo -e "  ${C_FAIL}Review errors above. Instance is NOT ready for live traffic.${C_RESET}"
        print_remediation
    elif [ "$WARN" -gt 0 ]; then
        echo ""
        echo -e "  ${C_WARN}${C_BOLD}RESULT: PASS with $WARN warning(s)${C_RESET}"
        echo -e "  ${C_WARN}Review warnings. Instance may be ready for live traffic.${C_RESET}"
        echo -e "${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
    else
        echo ""
        echo -e "  ${C_PASS}${C_BOLD}RESULT: PASS${C_RESET}"
        echo -e "  ${C_PASS}Instance validated. Ready for live traffic.${C_RESET}"
        echo -e "${C_BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}"
    fi
fi

# Exit code
if [ "$FAIL" -gt 0 ]; then
    exit 1
else
    exit 0
fi
