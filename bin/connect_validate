############################################################
# 19. SED file integrity (if helper dir provided)
############################################################

section "Helper SED File"
# Look for helper.sed in common locations relative to instance dir
helper_sed_candidates=(
    "$(dirname "$instance_alias_dir")/helper/helper.sed"
    "$(dirname "$instance_alias_dir")/helper.sed"
)
helper_sed_found=
for candidate in "${helper_sed_candidates[@]}"; do
    if [ -f "$candidate" ]; then
        helper_sed_found="$candidate"
        break
    fi
done

if [ -n "$helper_sed_found" ]; then
    pass "helper.sed found: $helper_sed_found"
    # Verify instance ID substitution is present
    if grep -q "$instance_id" "$helper_sed_found" 2>/dev/null; then
        pass "Instance ID substitution present in helper.sed"
    else
        warn "Instance ID not found in helper.sed - may not have been diffed yet"
    fi
    # Check for syntax errors in sed file
    sed_err=$(sed -n -f "$helper_sed_found" /dev/null 2>&1)
    if [ -z "$sed_err" ]; then
        pass "helper.sed syntax valid"
    else
        fail "helper.sed syntax error" "$sed_err"
    fi
else
    skip "helper.sed not found (run connect_diff to generate)"
fi

