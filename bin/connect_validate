# Summary
############################################################

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Results"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ✓ Passed : $PASS"
echo "  ✗ Failed : $FAIL"
echo "  ⚠ Warnings: $WARN"
echo "  - Skipped: $SKIP"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ "$FAIL" -gt 0 ]; then
    echo ""
    echo "  $FAIL test(s) failed. Review errors above."
    exit 1
elif [ "$WARN" -gt 0 ]; then
    echo ""
    echo "  All tests passed with $WARN warning(s). Review warnings above."
    exit 0
else
    echo ""
    echo "  All tests passed."
    exit 0
fi
