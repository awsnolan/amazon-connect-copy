cat <<EOD

Connect Cases
-------------
EOD
if [ -s "$instance_alias_dir_a/cases_domains.json" ]; then
    echo "NOTE: Connect Cases domains require manual setup on target instance."
    echo "      Cases fields, layouts, and templates saved for reference."
    echo "      Source: $instance_alias_dir_a/cases_domains.json"
    jq -r ".domainId + \" \" + .name" "$instance_alias_dir_a/cases_domains.json" |
    dos2unix |
    while read domain_id domain_name; do
        echo "  Cases domain: $domain_name - review saved files for manual recreation"
    done
else
    echo "No Connect Cases domains to process"
fi


