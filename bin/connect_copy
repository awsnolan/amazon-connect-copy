cat <<EOD

Outbound Campaigns
------------------
EOD
if [ -s "$instance_alias_dir_a/campaigns.json" ]; then
    echo "NOTE: Outbound campaigns reference Connect instance IDs and dialer configs."
    echo "      Review saved campaign files and recreate manually on target instance."
    echo "      Source: $instance_alias_dir_a/campaigns.json"
    jq -r ".id + \" \" + .name" "$instance_alias_dir_a/campaigns.json" |
    dos2unix |
    while read camp_id camp_name; do
        echo "  Campaign: $camp_name - manual recreation required"
    done
