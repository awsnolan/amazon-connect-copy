{
  "Version": "2019-10-30",
  "StartAction": "start-check-hours",
  "Actions": [
    {
      "Identifier": "start-check-hours",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "AFTER_HOURS_ARN",
        "InvocationTimeLimitSeconds": "8"
      },
      "Transitions": {
        "NextAction": "branch-hours",
        "Errors": [
          {"NextAction": "transfer-basic-queue", "ErrorType": "NoMatchingError"}
        ]
      }
    },
    {
      "Identifier": "branch-hours",
      "Type": "Compare",
      "Parameters": {
        "ComparisonValue": "$.External.isOpen"
      },
      "Transitions": {
        "NextAction": "after-hours-disconnect",
        "Conditions": [
          {
            "NextAction": "lookup-customer",
            "Condition": {"Operator": "Equals", "Operands": ["true"]}
          }
        ],
        "Errors": [
          {"NextAction": "transfer-basic-queue", "ErrorType": "NoMatchingCondition"}
        ]
      }
    },
    {
      "Identifier": "after-hours-disconnect",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    },
    {
      "Identifier": "lookup-customer",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "CUSTOMER_LOOKUP_ARN",
        "InvocationTimeLimitSeconds": "8"
      },
      "Transitions": {
        "NextAction": "set-attributes",
        "Errors": [
          {"NextAction": "lex-main-menu", "ErrorType": "NoMatchingError"}
        ]
      }
    },
    {
      "Identifier": "set-attributes",
      "Type": "UpdateContactAttributes",
      "Parameters": {
        "Attributes": {
          "CustomerName": "$.External.CustomerName",
          "AccountTier": "$.External.AccountTier"
        }
      },
      "Transitions": {
        "NextAction": "lex-main-menu",
        "Errors": [
          {"NextAction": "lex-main-menu", "ErrorType": "NoMatchingError"}
        ]
      }
    },
    {
      "Identifier": "lex-main-menu",
      "Type": "ConnectParticipantWithLexBot",
      "Parameters": {
        "LexV2Bot": {
          "AliasArn": "LEX_BOT_ALIAS_ARN"
        }
      },
      "Transitions": {
        "NextAction": "transfer-basic-queue",
        "Conditions": [
          {
            "NextAction": "transfer-basic-queue",
            "Condition": {"Operator": "Equals", "Operands": ["CheckBalance"]}
          },
          {
            "NextAction": "transfer-inbound-queue",
            "Condition": {"Operator": "Equals", "Operands": ["SpeakToAgent"]}
          }
        ],
        "Errors": [
          {"NextAction": "transfer-basic-queue", "ErrorType": "NoMatchingCondition"},
          {"NextAction": "transfer-basic-queue", "ErrorType": "NoMatchingError"}
        ]
      }
    },
    {
      "Identifier": "transfer-basic-queue",
      "Type": "TransferToQueue",
      "Parameters": {
        "QueueId": "BASIC_QUEUE_ARN"
      },
      "Transitions": {
        "NextAction": "disconnect-end",
        "Errors": [
          {"NextAction": "disconnect-end", "ErrorType": "NoMatchingError"}
        ]
      }
    },
    {
      "Identifier": "transfer-inbound-queue",
      "Type": "TransferToQueue",
      "Parameters": {
        "QueueId": "INBOUND_RECK_QUEUE_ARN"
      },
      "Transitions": {
        "NextAction": "disconnect-end",
        "Errors": [
          {"NextAction": "disconnect-end", "ErrorType": "NoMatchingError"}
        ]
      }
    },
    {
      "Identifier": "disconnect-end",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    }
  ]
}
